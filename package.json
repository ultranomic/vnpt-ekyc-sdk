{
  "name": "@ultranomic/vnpt-ekyc-sdk",
  "version": "3.0.1",
  "description": "VNPT eKYC SDK",
  "main": "dist/web-sdk-version-3.0.js",
  "types": "dist/web-sdk-version-3.0.d.ts",
  "exports": {
    ".": {
      "default": "./dist/web-sdk-version-3.0.js",
      "types": "./dist/web-sdk-version-3.0.d.ts"
    },
    "./browser": {
      "default": "./dist/lib/VNPTBrowserSDKAppV4.1.0.js",
      "types": "./dist/lib/VNPTBrowserSDKAppV4.1.0.d.ts"
    },
    "./qr-browser": {
      "default": "./dist/lib/VNPTQRBrowserApp.js",
      "types": "./dist/lib/VNPTQRBrowserApp.d.ts"
    },
    "./qr-upload": {
      "default": "./dist/lib/VNPTQRUpload.js",
      "types": "./dist/lib/VNPTQRUpload.d.ts"
    },
    "./assets/web-oval": "./dist/lib/web-oval.json",
    "./assets/mobile-oval": "./dist/lib/mobile-oval.json",
    "./assets/bg-vnpt": "./dist/lib/bg-vnpt.svg",
    "./assets/vietnamese-tutorial": "./dist/lib/vietnamese-tutorial.mp4",
    "./assets/english-tutorial": "./dist/lib/english-tutorial.mp4"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/ultranomic/vnpt-ekyc-sdk.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
